# Chravel Production Environment Configuration
# Copy this file to .env.production and fill in your values

# ===========================================
# SUPABASE CONFIGURATION (Required)
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Preferred modern key model:
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# Legacy compatibility (optional if publishable key is set):
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# GOOGLE MAPS (Required for Location Features)
# ===========================================
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ===========================================
# GOOGLE GEMINI / LOVABLE AI (Required for AI Concierge)
# ===========================================
# AI provider routing for edge functions:
# - AI_PROVIDER=gemini: direct Gemini API (recommended)
# - AI_PROVIDER=lovable: rollback mode to Lovable gateway
# - GEMINI_ENABLE_LOVABLE_FALLBACK=true: auto-fallback to Lovable if Gemini fails
AI_PROVIDER=gemini
GEMINI_ENABLE_LOVABLE_FALLBACK=true
# Primary key for direct Gemini calls
GEMINI_API_KEY=your-gemini-api-key
# Optional: default flash model for parser + concierge flows
# GEMINI_FLASH_MODEL=gemini-3.1-flash  # Text/chat model (non-realtime voice)
# Optional: dedicated Gemini key/model for speak-back TTS (falls back to GEMINI_API_KEY)
# GEMINI_TTS_API_KEY=your-gemini-tts-api-key
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# Get Lovable API key from: https://lovable.dev
# Used for rollback/fallback mode through Lovable AI Gateway (server-side only)
LOVABLE_API_KEY=your-lovable-api-key
# Separate unauth demo concierge endpoint (disabled by default in production)
ENABLE_DEMO_CONCIERGE=false
# Optional stricter demo limits
# DEMO_CONCIERGE_RPM=3
# DEMO_CONCIERGE_RPH=12
# Optional: Gemini Live voice preset for concierge voice sessions (default: Puck)
# VITE_GEMINI_VOICE_NAME=Puck
# Optional: Gemini Live model override for concierge voice sessions
# GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio  # Realtime voice model
# Optional: Edge Function controls for Gemini ephemeral voice tokens (server-side)
# GEMINI_EPHEMERAL_EXPIRE_MINUTES=30
# GEMINI_EPHEMERAL_NEW_SESSION_EXPIRE_SECONDS=60
# GEMINI_EPHEMERAL_USES=1

# ===========================================
# STRIPE (Required for Payments)
# ===========================================
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
# Server-side only (Edge Functions)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (from your Stripe Dashboard)
STRIPE_PLUS_PRICE_ID=price_your-plus-tier-price-id
STRIPE_PRO_PRICE_ID=price_your-pro-tier-price-id

# ===========================================
# RESEND (Required for Email Invitations)
# ===========================================
# Get from: https://resend.com/api-keys
# Server-side only (Edge Functions)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@chravel.app

# ===========================================
# APP CONFIGURATION
# ===========================================
VITE_APP_URL=https://chravel.app
VITE_APP_NAME=Chravel
VITE_ENVIRONMENT=production

# ===========================================
# FEATURE FLAGS (Optional)
# ===========================================
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_AI_CONCIERGE=true
VITE_CONCIERGE_TTS_ENABLED=false
VITE_ENABLE_STRIPE_PAYMENTS=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true

# ===========================================
# ANALYTICS (Optional)
# ===========================================
# Sentry Error Tracking
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ===========================================
# CAPACITOR / MOBILE CONFIGURATION
# ===========================================
# iOS App Store
IOS_BUNDLE_ID=com.chravel.app
IOS_APP_NAME=Chravel

# Android Play Store  
ANDROID_PACKAGE_NAME=com.chravel.app
ANDROID_APP_NAME=Chravel

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# Content Security Policy
VITE_CSP_REPORT_URI=https://chravel.report-uri.com/r/d/csp/enforce

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ===========================================
# DEPLOYMENT CONFIGURATION
# ===========================================
# Vercel/Render/Railway deployment URL
DEPLOYMENT_URL=https://chravel.app

# CDN Configuration
CDN_URL=https://cdn.chravel.app

# ===========================================
# DEVELOPMENT OVERRIDES (Remove in Production)
# ===========================================
# VITE_USE_LOCAL_STORAGE=false
# VITE_MOCK_STRIPE=false
# VITE_DISABLE_ANALYTICS=false

# ===========================================
# INTERNAL SECURITY SECRETS (Required for background jobs & notifications)
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set in Supabase Dashboard > Edge Functions > Secrets (NOT here)
# CRON_SECRET=                    — Protects all scheduled edge functions
# NOTIFICATION_DISPATCH_SECRET=   — Inter-function auth for notification delivery

# ===========================================
# GOOGLE VISION (Required for receipt OCR)
# ===========================================
# Enable Cloud Vision API at: https://console.cloud.google.com/apis/library/vision.googleapis.com
# Set in Supabase Dashboard > Edge Functions > Secrets
# GOOGLE_VISION_API_KEY=          — Google Cloud Vision API key (separate from Maps key)

# ===========================================
# GETSTREAM CHAT (Required for messaging)
# ===========================================
# Get from: https://getstream.io/dashboard/ → App → Access Keys
# STREAM_API_KEY and STREAM_API_SECRET go in Supabase Edge Function secrets
# VITE_STREAM_API_KEY=            — Public key (safe for frontend bundle)
# STREAM_API_KEY=                 — Same value, also needed in Supabase secrets
# STREAM_API_SECRET=              — Server-only secret, Supabase secrets only
# STREAM_WEBHOOK_SECRET=          — Webhook signing secret (Supabase secrets only)
# STREAM_ADMIN_SECRET=            — Admin gate for stream-setup-permissions (Supabase secrets only)

# ===========================================
# APPLE PUSH NOTIFICATIONS (Required for iOS)
# ===========================================
# Get from: https://developer.apple.com → Certificates, Identifiers & Profiles → Keys
# Set in Supabase Dashboard > Edge Functions > Secrets
# APNS_KEY_ID=                    — 10-character key ID
# APNS_TEAM_ID=                   — Apple Developer Team ID
# APNS_PRIVATE_KEY=               — Contents of .p8 file (server-only)
# APNS_BUNDLE_ID=com.chravel.app  — iOS bundle ID

# ===========================================
# FIREBASE CLOUD MESSAGING V1 (Required for Android/Web push)
# ===========================================
# Uses the same GCP service account as Vertex AI — no separate secret needed.
# Ensure "Firebase Cloud Messaging API" is enabled at:
#   https://console.cloud.google.com/apis/library/fcm.googleapis.com
# Required secrets (set in Supabase Dashboard > Edge Functions > Secrets):
# VERTEX_SERVICE_ACCOUNT_KEY=     — Base64-encoded GCP service account JSON
# VERTEX_PROJECT_ID=              — GCP/Firebase project ID (e.g., the-travel-app-467106)

# ===========================================
# GMAIL IMPORT (Required for Smart Import from email)
# ===========================================
# Set up OAuth at: https://console.cloud.google.com → APIs & Services → Credentials
# Set in Supabase Dashboard > Edge Functions > Secrets
# GOOGLE_CLIENT_ID=               — OAuth client ID
# GOOGLE_CLIENT_SECRET=           — OAuth client secret (server-only)
# GOOGLE_REDIRECT_URI=https://chravel.app/api/gmail/oauth/callback
# GOOGLE_CALENDAR_REDIRECT_URI=https://chravel.app/api/google-calendar/oauth/callback
# GOOGLE_ADDITIONAL_REDIRECT_URIS= — extra allowed OAuth redirect URIs, comma-separated
# GMAIL_TOKEN_ENCRYPTION_KEY=     — 32-char AES key (self-generate, see scripts/)
# CALENDAR_TOKEN_ENCRYPTION_KEY=  — base64 of 32 random bytes (openssl rand -base64 32)
# OAUTH_STATE_SIGNING_SECRET=     — HMAC key (self-generate, see scripts/)

# ===========================================
# ADDITIONAL EDGE FUNCTION SECRETS & CONFIG (server-only, Supabase Dashboard)
# ===========================================
# Referenced via Deno.env.get() in supabase/functions; documented here so the
# env-coverage scanner (scripts/check-env-coverage.ts) can verify them.
#
# AI / Concierge
# AI_GATEWAY_API_KEY=             — Vercel AI Gateway key for OpenAI Realtime voice (mint-realtime-token / realtime-voice-session)
# CONCIERGE_TOOL_MODEL=           — Gemini model used for concierge tool calls
# BROWSE_WEBSITE_MODEL=           — Gemini model for the website-browsing concierge tool
# EMBEDDING_MODEL=                — Model used to generate embeddings
# EMBEDDING_DIMENSIONS=           — Vector dimensions for embeddings
# RAG_SOFT_TIMEOUT_MS=            — Soft timeout (ms) for RAG retrieval before fallback
# ENABLE_COMBINED_GROUNDING=      — Feature flag: combined RAG + Maps grounding
# ENABLE_MAPS_GROUNDING=          — Feature flag: Google Maps grounding for concierge
# ENABLE_THINKING_CONFIG=         — Feature flag: Gemini thinking config
# CONCIERGE_FREE_MONTHLY_TOKEN_BUDGET=      — Monthly concierge token budget (free tier)
# CONCIERGE_EXPLORER_MONTHLY_TOKEN_BUDGET=  — Monthly concierge token budget (Explorer tier)
# CONCIERGE_FREQUENT_MONTHLY_TOKEN_BUDGET=  — Monthly concierge token budget (Frequent tier)
# SMART_IMPORT_FREE_LIMIT=        — Free-tier Smart Import usage limit
#
# Google APIs (server-side)
# GOOGLE_CLOUD_TTS_API_KEY=       — Google Cloud Text-to-Speech key (concierge voice TTS)
# GOOGLE_CUSTOM_SEARCH_CX=        — Google Programmable Search engine ID
# GOOGLE_SEARCH_CONSOLE_API_KEY=  — Google Search Console API key (SEO dashboard)
#
# Email (SendGrid — send-email-with-retry)
# SENDGRID_API_KEY=               — SendGrid API key for transactional email
# SENDGRID_FROM_EMAIL=            — SendGrid verified from-address
#
# Sign in with Apple / APNs (store-apple-token, verify-identity)
# APPLE_CLIENT_ID=                — Sign in with Apple services ID
# APPLE_TEAM_ID=                  — Apple Developer Team ID
# APPLE_KEY_ID=                   — Sign in with Apple key ID
# APPLE_P8_PRIVATE_KEY=           — Sign in with Apple .p8 private key (server-only)
# APPLE_TOKEN_ENCRYPTION_KEY=     — AES key encrypting stored Apple tokens
# APNS_ENVIRONMENT=               — APNs environment: sandbox | production
#
# Billing / SEO / misc integrations
# REVENUECAT_SECRET_API_KEY=      — RevenueCat server (secret) API key
# SEMRUSH_API_KEY=                — Semrush API key (SEO tooling)
# VAPID_SUBJECT=                  — VAPID subject (mailto: or URL) for Web Push
#
# Platform / deploy / infra
# SITE_URL=                       — Canonical site URL used by edge functions for links/redirects
# ADDITIONAL_ALLOWED_ORIGINS=     — Extra CORS origins (comma-separated) allowed by edge functions
# SUPABASE_JWT_SECRET=            — Supabase JWT signing secret (server-only token verification)
# SUPER_ADMIN_BOOTSTRAP_EMAILS=   — Comma-separated founder emails seeded into public.super_admins
# IMAGE_PROXY_CACHE_CONTROL=      — Cache-Control header value for image-proxy responses
# IMAGE_PROXY_MAX_BYTES=          — Max response size (bytes) for image-proxy
# DENO_ENV=                       — Deno runtime environment marker (e.g. production)
# DEPLOY_SHA=                     — Git SHA injected at deploy (health / telemetry)
# DEPLOY_VERSION=                 — App version injected at deploy (health / telemetry)
