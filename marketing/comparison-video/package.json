{
  "name": "chravel-comparison-video",
  "version": "1.0.0",
  "private": true,
  "description": "ChravelApp vs. many-apps product comparison video (Remotion)",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render ComparisonVideo out/chravel-comparison.mp4 --browser-executable=/opt/pw-browsers/chromium --chrome-mode=chrome-for-testing --timeout=120000 --concurrency=1",
    "still": "remotion still ComparisonVideo --browser-executable=/opt/pw-browsers/chromium --chrome-mode=chrome-for-testing --timeout=120000 --concurrency=1"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.489",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "^4.0.489"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
